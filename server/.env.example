# Server Port
PORT=4000

# Corporate SMTP Configuration (for Emails)
# SMTP_HOST=mail.corporate.ru
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=notifications@corporate.ru
# SMTP_PASS=secretpassword
# SMTP_FROM="Refund Manager <notifications@corporate.ru>"

# Corporate Rocket Chat Configuration
# Can be an Incoming Webhook URL:
# ROCKETCHAT_URL=https://chat.corporate.ru/hooks/webhook-id-string
# Or the REST API base URL and token/credentials:
# ROCKETCHAT_URL=https://chat.corporate.ru
# ROCKETCHAT_TOKEN=your-rocket-chat-api-token
# ROCKETCHAT_USER=your-rocket-chat-user-id
# ROCKETCHAT_CHANNEL=#refund-alerts
